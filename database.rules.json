{
  // Realtime Database security rules for Finance Hub.
  // Both Elly and Eric must be able to read/write the shared tree.
  // Eric's monthly bills + allocate-from-payables broke because the old
  // rules only granted access to Elly's account.
  // Compare/Insights/Household views need each user to READ the other's
  // budget, so reads are open to both authorised emails.
  // Deploy: firebase deploy --only database
  "rules": {
    "finance-hub": {
      ".read": "auth != null && (auth.token.email == 'ellyhizon1@gmail.com' || auth.token.email == 'ericdefelix@gmail.com')",
      "budget": {
        ".write": "auth != null && (auth.token.email == 'ellyhizon1@gmail.com' || auth.token.email == 'ericdefelix@gmail.com')"
      },
      "eric-budget": {
        ".write": "auth != null && (auth.token.email == 'ellyhizon1@gmail.com' || auth.token.email == 'ericdefelix@gmail.com')"
      },
      "payables": {
        ".write": "auth != null && (auth.token.email == 'ellyhizon1@gmail.com' || auth.token.email == 'ericdefelix@gmail.com')"
      },
      "admin-settings": {
        ".write": "auth != null && auth.token.email == 'ellyhizon1@gmail.com'"
      }
    }
  }
}
